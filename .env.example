# ─────────────────────────────────────────────────────────────────────────────
# CareerPilot environment variables
# Copy to .env.local for development. Production secrets live in Vercel.
# Any value flagged REQUIRED must be set for the app to boot in production.
#
# SECRET HYGIENE — DO NOT PUT REAL VALUES IN THIS FILE.
# This file is committed to git. Real keys go in .env.local (gitignored).
# If a real key ever lands here by accident: rotate it immediately at the
# provider and force-push a clean .env.example.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (REQUIRED in all environments) ─────────────────────────────────────
NODE_ENV="development"

# ── Database — Supabase ────────────────────────────────────────────────────
# Get both URLs from: Supabase project → Settings → Database → Connection string
#   DATABASE_URL = "Connection pooling" enabled (port 6543, pgbouncer)
#   DIRECT_URL   = "Connection pooling" disabled (port 5432, direct)
# The app uses DATABASE_URL at runtime; `prisma migrate` uses DIRECT_URL.
# Append ?pgbouncer=true&connection_limit=1 to the pooled URL.
DATABASE_URL=""
DIRECT_URL=""

NEXTAUTH_SECRET=""   # openssl rand -base64 32  (must be >=32 chars)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── AI providers ────────────────────────────────────────────────────────────
# Claude is primary; OpenAI is fallback. Admin can override per use-case.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL_DEFAULT="claude-sonnet-4-6"
OPENAI_API_KEY=""
OPENAI_MODEL_DEFAULT="gpt-4o-mini"
OPENAI_BASE_URL=""   # optional override (Azure, proxy, etc.)
AI_DEMO_MODE="false" # "true" to return canned responses (no API calls)

# ── Payments — Ziina ────────────────────────────────────────────────────────
# https://docs.ziina.com/api-reference/payment-intent/index
ZIINA_API_KEY=""              # Bearer token with write_payment_intents scope
ZIINA_WEBHOOK_SECRET=""       # HMAC-SHA256 secret set when registering the webhook
ZIINA_TEST_MODE="false"       # "true" sends test:true with every intent

# ── Payments — WhatsApp ─────────────────────────────────────────────────────
# Admin's WhatsApp number that receives payment requests (E.164 format).
WHATSAPP_ADMIN_NUMBER=""      # e.g. +9715XXXXXXXX

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="hello@careerpilot.ae"

# ── Storage (Supabase) ──────────────────────────────────────────────────────
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="careerpilot"

# ── Rate limit / queue (Upstash Redis) ──────────────────────────────────────
# Optional in dev — limiter becomes a no-op when absent.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Encryption ──────────────────────────────────────────────────────────────
# Base64 of 32 random bytes — used to encrypt PII at the application layer.
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=""

# ── Observability (Sentry) ──────────────────────────────────────────────────
# Optional — Sentry is fully skipped when DSN is absent.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT=""

# ── Google OAuth (Phase 6 — Gmail-backed automation) ────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://<your-domain>/api/email-accounts/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# ── Cron (Phase 6 — automation runner + subscription expiry) ────────────────
# Random secret used to authenticate /api/cron/* endpoints. Vercel cron sends
# this as a bearer token via the Authorization header.
# Generate: openssl rand -base64 32
CRON_SECRET=""
